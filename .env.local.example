# =========================================================
# .env.local — Pacientes App
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local — já está no .gitignore.
# =========================================================

# ---------------------------------------------------------
# Supabase
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
# ---------------------------------------------------------

# Project URL (Dashboard → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# anon/public key (Dashboard → Settings → API → Project API keys → anon public)
# Essa chave é segura para expor no client — protegida por RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key (Dashboard → Settings → API → Project API keys → service_role)
# ⚠️ NUNCA expor no client! Bypass RLS. Usada apenas em server components e Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project ID (Dashboard → Settings → General → Reference ID)
SUPABASE_PROJECT_ID=abcdefghijklmnop

# ---------------------------------------------------------
# Z-API (WhatsApp) — Checkpoint 3b decision
# Painel: https://app.z-api.io/
# Docs: https://developer.z-api.io/
# ---------------------------------------------------------

# ID da instância (Painel Z-API → sua instância → aba "Informações" → ID)
ZAPI_INSTANCE_ID=3A1B2C3D4E5F6G7H8I9J

# Token da instância (Painel Z-API → sua instância → aba "Informações" → Token)
ZAPI_TOKEN=Ab1Cd2Ef3Gh4Ij5Kl6Mn7Op8Qr9St0

# Client-Token (Painel Z-API → Minha Conta → Segurança da conta)
# ⚠️ Header obrigatório em toda request; também valida o webhook de status
ZAPI_CLIENT_TOKEN=Fa1Fb2Fc3Fd4Fe5Ff6F

# ---------------------------------------------------------
# App
# ---------------------------------------------------------

# URL base do app (em produção: https://seu-dominio.com ou https://seu-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
